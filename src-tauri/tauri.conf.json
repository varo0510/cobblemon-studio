{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cobblemon Studio",
  "version": "0.4.0",
  "identifier": "com.varo.cobblemon-studio",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cobblemon Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 1000,
        "minHeight": 640,
        "backgroundColor": "#0e1014"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/varo0510/cobblemon-studio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCQTc3OTAxQjk1N0RGMzAKUldRdzMxZTVBWG1udXpvLys0ckJGR2svTXdYdUZwcHVFY3NLVnhCTDdtZWhCMlovM0twbXJRNHAK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
